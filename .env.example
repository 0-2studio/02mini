# 02mini Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# AI Provider Configuration
# ============================================

# AI Provider Type: openai | anthropic | gemini | bedrock | azure | ollama | openrouter | together | custom
AI_PROVIDER_TYPE=openai

# AI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Base URL (optional, for custom endpoints or proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# AI Model (optional, defaults shown below)
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI Parameters (optional)
# AI_MAX_TOKENS=2000
# AI_TEMPERATURE=0.7

# OpenAI Organization (optional)
# OPENAI_ORGANIZATION=your_org_id

# ============================================
# Gateway Configuration
# ============================================

# Gateway Authentication
MINI_GATEWAY_TOKEN=your_secure_random_token_here

# Gateway Port (optional, default: 18789)
# GATEWAY_PORT=18789

# Gateway Host (optional, default: 127.0.0.1)
# GATEWAY_HOST=127.0.0.1

# ============================================
# Channel Bot Tokens
# ============================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here