{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "fetch": {
      "command": "npx",
      "args": ["mcp-fetch-server"],
      "env": {
        "DEFAULT_LIMIT": "50000"
      }
    },
    "mcp-server-code-runner": {
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/mcp-server-code-runner"
      ],
      "values": {}
    }
  }
}
