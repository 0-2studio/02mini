# ================================
# 02mini - Git Ignore Configuration
# ================================

# ----- Dependencies -----
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lock
bun.lockb

# ----- Build Output -----
build/
dist/
*.tsbuildinfo

# ----- Environment Variables (Sensitive) -----
.env
.env.local
.env.*.local
# Keep example file
!.env.example

# ----- IDE & Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# ----- OS Files -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Runtime Data -----
# Cron job storage
memory/cron-store.json

# Session data
sessions/

# Temporary files
tmp/
temp/

# ----- Memory System (User Data) -----
# Daily logs (auto-generated)
memory/daily-logs/*
!memory/daily-logs/.gitkeep

# Daily summaries (auto-generated)
memory/daily-summaries/*
!memory/daily-summaries/.gitkeep

# Self reflections (personal)
memory/self-reflections/*
!memory/self-reflections/.gitkeep

# Knowledge base (personal)
memory/knowledge/*
!memory/knowledge/.gitkeep

# Group members cache
memory/group-members/*
!memory/group-members/.gitkeep

# Planned changes (temporary)
memory/planned-changes/*
!memory/planned-changes/.gitkeep

# Keep essential memory files
!memory/user-profile.md
!memory/skills-inventory.md
!memory/README.md

# ----- Generated Files -----
files/*
!files/README.md
!files/.gitkeep
!files/qq-uploads/.gitkeep

# QQ uploads (user files)
files/qq-uploads/*
!files/qq-uploads/.gitkeep

# ----- Backup Files -----
backup/
*.backup
*.bak

# ----- MCP Cache -----
.mcp-cache/

# ----- Test & Coverage -----
coverage/
.nyc_output/

# ----- Cache -----
.cache/
.parcel-cache/
